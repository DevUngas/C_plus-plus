#include <iostream>
#include <map>
#include <string>

using namespace std;

class SIM {
private:
    // Use a struct to store both Quantity and Price for each product
    struct Product {
        string quantity;
        string price;
    };

    // Using a map to store Product entries (name -> Product)
    map<string, Product> SIM;

public:
    // Create a new Product entry
    void addProduct(const string& name, const string& quantity, const string& price) {
        // Check if the product already exists
        if (SIM.find(name) != SIM.end()) {
            cout << "Product already exists!" << endl;
        } else {
            SIM[name] = {quantity, price};
            cout << "Product Successfully Created!" << endl;
        }
    }

    // View all Products in the Storage
    void viewProducts() {
        if (SIM.empty()) {
            cout << "\t\t\t\t\t\t\t\t\tEMPTY STORAGE." << endl;
        } else {
            cout << "\t\t\t\t\t\tProduct List\n";
            for (const auto& product : SIM) {
                cout << "Product Name: " << product.first
                     << "\nQuantity: " << product.second.quantity <<"pcs"
                     << "\nPrice: " << product.second.price << "₱"
                     << "\n\n";
            }
        }
    }

    // Update a Product's Quantity and Price
    void updateProduct(const string& name, const string& newQuantity, const string& newPrice) {
        auto it = SIM.find(name);
        if (it != SIM.end()) {
            it->second.quantity = newQuantity;
            it->second.price = newPrice;
            cout << "Product updated successfully!" << endl;
        } else {
            cout << "Product not found!" << endl;
        }
    }

    // Delete a Product by name
    void deleteProduct(const string& name) {
        auto it = SIM.find(name);
        if (it != SIM.end()) {
            SIM.erase(it);
            cout << "Product deleted successfully!" << endl;
        } else {
            cout << "Product not found!" << endl;
        }
    }
};

int main() {
    SIM inventory;
    int choice;
    string name, quantity, price;

    do {
        // Display menu
        cout << "\n\t\t\t\t\t\t===== STORAGE INVENTORY MANAGEMENT =====\n\n";
        cout << "1. Create New Product\n";
        cout << "2. Product List\n";
        cout << "3. Update Inventory\n";
        cout << "4. Delete Product\n";
        cout << "5. Exit\n";
        cout << "Enter your choice: ";
        cin >> choice;
        cout << "\n";
        cin.ignore();  // To handle newline character after choice input

        switch (choice) {
        case 1:
            // Add a new Product
            cout << "Product Name: ";
            getline(cin, name);
            cout << "Quantity: ";
            getline(cin, quantity);
            cout << "Price per unit: ";
            getline(cin, price);
            inventory.addProduct(name, quantity, price);
            break;

        case 2:
            // View all Products
            inventory.viewProducts();
            break;

        case 3:
            // Update a Product
            cout << "Enter Product name to update: ";
            getline(cin, name);
            cout << "New Quantity: ";
            getline(cin, quantity);
            cout << "New Price per unit: ";
            getline(cin, price);
            inventory.updateProduct(name, quantity, price);
            break;

        case 4:
            // Delete a Product
            cout << "Enter Product name to delete: ";
            getline(cin, name);
            inventory.deleteProduct(name);
            break;

        case 5:
            // Exit the program
            cout << "Exiting program...\n";
            break;

        default:
            cout << "Invalid choice, please try again.\n";
            break;
        }
    } while (choice != 5);

    return 0;
}
